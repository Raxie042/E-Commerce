# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=marketplace_user
DB_PASSWORD=CHANGE_ME_strong_random_password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ISSUER=marketplace-api
JWT_AUDIENCE=marketplace-client
# Must be >= 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_char_random_secret_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# From: stripe listen --forward-to ... / Stripe dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=10

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL buyers visit (used for CORS on the API)
FRONTEND_URL=https://yourdomain.com
# Internal URL the frontend container uses to reach the API
# In Docker Compose this is the service name + port
API_URL=http://api:8080
