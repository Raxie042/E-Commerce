{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "http://localhost:3000",
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5436;Database=marketplace;Username=marketplace_user;Password=marketplace_pass"
  },
  "Jwt": {
    "Issuer": "marketplace-api",
    "Audience": "marketplace-client",
    "Key": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_IN_ENV"
  },
  "Stripe": {
    "SecretKey": "STRIPE_SECRET_KEY_FROM_ENV",
    "WebhookSecret": "STRIPE_WEBHOOK_SECRET_FROM_ENV",
    "PlatformFeePercent": 10
  }
}
